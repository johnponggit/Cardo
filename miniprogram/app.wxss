/* app.wxss - 全局样式 玻璃拟态风格 */

/* 主题变量 */
page {
  --primary-color: #6C5CE7;
  --primary-light: #A29BFE;
  --primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  --success-color: #00B894;
  --success-light: #55EFC4;
  --warning-color: #FDCB6E;
  --error-color: #E17055;
  --text-primary: #2D3436;
  --text-secondary: #636E72;
  --text-light: #B2BEC3;
  --bg-gradient: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  --card-bg: rgba(255, 255, 255, 0.7);
  --card-border: rgba(255, 255, 255, 0.5);
  --glass-bg: rgba(255, 255, 255, 0.25);
  --glass-border: rgba(255, 255, 255, 0.18);
  --shadow-light: 0 8rpx 32rpx rgba(31, 38, 135, 0.15);
  --shadow-medium: 0 8rpx 32rpx rgba(31, 38, 135, 0.25);

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: var(--text-primary);
  background: linear-gradient(135deg, #E0C3FC 0%, #8EC5FC 100%);
  background-attachment: fixed;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 通用容器 */
.container {
  padding: 24rpx;
  min-height: 100vh;
  background: linear-gradient(135deg, #E0C3FC 0%, #8EC5FC 100%);
  background-attachment: fixed;
}

/* 玻璃卡片 */
.glass-card {
  background: var(--card-bg);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  border: 1rpx solid var(--card-border);
  box-shadow: var(--shadow-light);
  overflow: hidden;
}

/* 普通卡片样式 */
.card {
  background: var(--card-bg);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  border: 1rpx solid var(--card-border);
  box-shadow: var(--shadow-light);
  padding: 28rpx;
  margin-bottom: 24rpx;
}

/* 渐变卡片 */
.gradient-card {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.9) 0%, rgba(118, 75, 162, 0.9) 100%);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  box-shadow: var(--shadow-medium);
  padding: 32rpx;
  color: #FFFFFF;
}

/* 按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #FFFFFF;
  border-radius: 50rpx;
  padding: 24rpx 48rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
  transition: all 0.3s ease;
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(10rpx);
  color: var(--primary-color);
  border-radius: 50rpx;
  padding: 24rpx 48rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: var(--shadow-light);
}

.btn-secondary::after {
  border: none;
}

/* 输入框样式 */
.input {
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(10rpx);
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  box-shadow: inset 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.textarea {
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(10rpx);
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  min-height: 180rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  box-shadow: inset 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

/* 标签样式 */
.tag {
  display: inline-block;
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  margin-right: 12rpx;
  backdrop-filter: blur(10rpx);
}

.tag-primary {
  background: rgba(108, 92, 231, 0.2);
  color: var(--primary-color);
  border: 1rpx solid rgba(108, 92, 231, 0.3);
}

.tag-success {
  background: rgba(0, 184, 148, 0.2);
  color: var(--success-color);
  border: 1rpx solid rgba(0, 184, 148, 0.3);
}

.tag-warning {
  background: rgba(253, 203, 110, 0.3);
  color: #B7791F;
  border: 1rpx solid rgba(253, 203, 110, 0.4);
}

/* 状态标签 */
.status-pending {
  color: var(--text-light);
}

.status-doing {
  color: var(--primary-color);
}

.status-done {
  color: var(--success-color);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  color: var(--text-secondary);
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
  opacity: 0.8;
}

.empty-state text {
  font-size: 28rpx;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.5), transparent);
  margin: 24rpx 0;
}

/* 列表项 */
.list-item {
  display: flex;
  align-items: center;
  padding: 28rpx;
  background: var(--card-bg);
  backdrop-filter: blur(20rpx);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.3);
}

.list-item:last-child {
  border-bottom: none;
}

/* 浮动按钮 */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 180rpx;
  width: 112rpx;
  height: 112rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 40rpx rgba(102, 126, 234, 0.5);
  z-index: 100;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.fab image {
  width: 52rpx;
  height: 52rpx;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 32rpx;
  color: var(--text-secondary);
  font-size: 26rpx;
}

/* TabBar 样式增强 */
.tabbar-active {
  color: var(--primary-color);
}