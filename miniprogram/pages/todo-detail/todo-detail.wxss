/* pages/todo-detail/todo-detail.wxss 玻璃拟态风格 */

.container {
  padding: 24rpx;
  padding-bottom: 200rpx;
  background: linear-gradient(135deg, #E0C3FC 0%, #8EC5FC 100%);
  background-attachment: fixed;
  min-height: 100vh;
}

.form-item {
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  padding: 28rpx;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(31, 38, 135, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.form-label {
  font-size: 28rpx;
  color: #2D3436;
  margin-bottom: 16rpx;
  font-weight: 600;
}

.required {
  color: #E17055;
}

.input {
  width: 100%;
  height: 88rpx;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(10rpx);
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  line-height: 88rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: inset 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.link-input-field {
  flex: 1;
  width: auto;
}

.flex-1 {
  flex: 1;
}

.link-input {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.btn-paste {
  flex-shrink: 0;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.2) 0%, rgba(118, 75, 162, 0.2) 100%);
  color: #6C5CE7;
  border: 1rpx solid rgba(102, 126, 234, 0.3);
  font-size: 26rpx;
  padding: 18rpx 28rpx;
  border-radius: 30rpx;
  font-weight: 500;
}

.link-preview {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.5);
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  margin-top: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.preview-content {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.preview-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 12rpx;
}

.preview-text {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.preview-title {
  font-size: 26rpx;
  color: #2D3436;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-weight: 500;
}

.preview-url {
  font-size: 22rpx;
  color: #636E72;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.btn-open {
  flex-shrink: 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #FFFFFF;
  font-size: 24rpx;
  margin-left: 16rpx;
  border-radius: 30rpx;
  padding: 12rpx 24rpx;
}

.picker-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.6);
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #2D3436;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.arrow-icon {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.6;
}

/* 状态选项 */
.status-options {
  display: flex;
  gap: 16rpx;
}

.status-option {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 22rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #636E72;
  transition: all 0.3s ease;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  font-weight: 500;
}

.status-option.active {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.8) 0%, rgba(118, 75, 162, 0.8) 100%);
  color: #FFFFFF;
  border-color: transparent;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.25);
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 10rpx;
}

.status-dot.pending {
  background: #B2BEC3;
}

.status-dot.doing {
  background: #6C5CE7;
}

.status-dot.done {
  background: #00B894;
}

/* 优先级选项 */
.priority-options {
  display: flex;
  gap: 16rpx;
}

.priority-option {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 22rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #636E72;
  transition: all 0.3s ease;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  font-weight: 500;
}

.priority-option.active {
  color: #FFFFFF;
  border-color: transparent;
}

.priority-option.active.high {
  background: linear-gradient(135deg, #E17055 0%, #D63031 100%);
  box-shadow: 0 4rpx 16rpx rgba(225, 112, 85, 0.3);
}

.priority-option.active.medium {
  background: linear-gradient(135deg, #FDCB6E 0%, #F39C12 100%);
  box-shadow: 0 4rpx 16rpx rgba(253, 203, 110, 0.3);
}

.priority-option.active.low {
  background: linear-gradient(135deg, #00B894 0%, #00CEC9 100%);
  box-shadow: 0 4rpx 16rpx rgba(0, 184, 148, 0.3);
}

.priority-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 10rpx;
}

.textarea {
  width: 100%;
  min-height: 200rpx;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(10rpx);
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  line-height: 1.6;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: inset 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.card-link {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.15) 0%, rgba(118, 75, 162, 0.15) 100%);
  padding: 20rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(102, 126, 234, 0.2);
}

.card-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 12rpx;
}

.card-link text {
  color: #6C5CE7;
  font-size: 28rpx;
  font-weight: 500;
}

/* 按钮区域 */
.form-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.btn-delete {
  flex: 1;
  background: rgba(255, 255, 255, 0.7);
  color: #E17055;
  border: 2rpx solid rgba(225, 112, 85, 0.5);
  font-size: 28rpx;
  border-radius: 50rpx;
  font-weight: 500;
  backdrop-filter: blur(10rpx);
}

.btn-submit {
  flex: 2;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #FFFFFF;
  font-size: 28rpx;
  border-radius: 50rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

/* 创建卡片区域 */
.create-card-section {
  margin-top: 40rpx;
}

.divider-text {
  text-align: center;
  margin-bottom: 20rpx;
}

.divider-text text {
  font-size: 26rpx;
  color: #636E72;
}

.btn-create-card {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #00B894 0%, #00CEC9 100%);
  color: #FFFFFF;
  font-size: 28rpx;
  border-radius: 50rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(0, 184, 148, 0.3);
}

.btn-create-card image {
  width: 36rpx;
  height: 36rpx;
  margin-right: 12rpx;
}