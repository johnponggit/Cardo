/* pages/index/index.wxss 玻璃拟态风格 */

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: linear-gradient(135deg, #E0C3FC 0%, #8EC5FC 100%);
  background-attachment: fixed;
  padding: 24rpx;
  padding-bottom: 120rpx;
}

/* 欢迎区 */
.welcome-section {
  padding: 32rpx 16rpx;
  margin-bottom: 24rpx;
}

.greeting {
  display: block;
  font-size: 52rpx;
  font-weight: 700;
  color: #2D3436;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 8rpx rgba(255, 255, 255, 0.5);
}

.date {
  font-size: 28rpx;
  color: #636E72;
  text-shadow: 0 1rpx 4rpx rgba(255, 255, 255, 0.5);
}

/* 统计卡片 */
.stats-section {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  flex: 1;
  border-radius: 28rpx;
  padding: 28rpx;
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  box-shadow: 0 8rpx 32rpx rgba(31, 38, 135, 0.15);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  overflow: hidden;
  position: relative;
}

.todo-stat {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.85) 0%, rgba(118, 75, 162, 0.85) 100%);
  color: #FFFFFF;
}

.card-stat {
  background: linear-gradient(135deg, rgba(0, 184, 148, 0.85) 0%, rgba(0, 206, 201, 0.85) 100%);
  color: #FFFFFF;
}

.stat-card::before {
  content: '';
  position: absolute;
  top: -50rpx;
  right: -50rpx;
  width: 150rpx;
  height: 150rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.stat-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.stat-icon {
  width: 44rpx;
  height: 44rpx;
  margin-right: 12rpx;
  opacity: 0.95;
}

.stat-title {
  font-size: 26rpx;
  font-weight: 500;
  opacity: 0.95;
}

.stat-body {
  display: flex;
  justify-content: space-between;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #FFFFFF;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.stat-value.doing {
  color: rgba(255, 255, 255, 0.9);
}

.stat-value.done {
  color: rgba(255, 255, 255, 0.85);
}

.stat-value.due {
  color: rgba(255, 255, 255, 0.9);
}

.stat-value.new {
  color: rgba(255, 255, 255, 0.85);
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 6rpx;
}

/* 复习入口 */
.review-section {
  margin-bottom: 24rpx;
}

.review-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, rgba(253, 203, 110, 0.9) 0%, rgba(255, 165, 0, 0.9) 100%);
  border-radius: 24rpx;
  padding: 28rpx;
  backdrop-filter: blur(20rpx);
  box-shadow: 0 8rpx 32rpx rgba(253, 203, 110, 0.3);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.review-content {
  display: flex;
  align-items: center;
}

.review-icon {
  width: 56rpx;
  height: 56rpx;
  margin-right: 20rpx;
}

.review-text {
  display: flex;
  flex-direction: column;
}

.review-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.review-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 6rpx;
}

.arrow-icon {
  width: 36rpx;
  height: 36rpx;
  opacity: 0.9;
}

/* 近期待办 */
.recent-section {
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(31, 38, 135, 0.15);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 8rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D3436;
}

.section-more {
  font-size: 26rpx;
  color: #6C5CE7;
  font-weight: 500;
}

.recent-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.recent-item {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(31, 38, 135, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
}

.item-status {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.item-status.pending {
  background: #B2BEC3;
}

.item-status.doing {
  background: #6C5CE7;
  box-shadow: 0 0 12rpx rgba(108, 92, 231, 0.5);
}

.item-status.done {
  background: #00B894;
}

.item-content {
  flex: 1;
  min-width: 0;
}

.item-title {
  font-size: 28rpx;
  color: #2D3436;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}

.item-category {
  font-size: 24rpx;
  color: #636E72;
  margin-top: 4rpx;
  display: block;
}

.item-priority {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  margin-left: 12rpx;
}

.priority-1 {
  background: #E17055;
  box-shadow: 0 0 12rpx rgba(225, 112, 85, 0.5);
}

.priority-2 {
  background: #FDCB6E;
}

.priority-3 {
  background: #00B894;
}

.empty-recent {
  text-align: center;
  padding: 40rpx;
  color: #636E72;
}

.btn-add {
  display: inline-block;
  margin-top: 16rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #FFFFFF;
  font-size: 26rpx;
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(102, 126, 234, 0.3);
}

/* 快捷操作 */
.quick-actions {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 8rpx 32rpx rgba(31, 38, 135, 0.15);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  box-shadow: 0 8rpx 24rpx rgba(31, 38, 135, 0.15);
  backdrop-filter: blur(10rpx);
}

.action-icon.todo {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.8) 0%, rgba(118, 75, 162, 0.8) 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.action-icon.card {
  background: linear-gradient(135deg, rgba(0, 184, 148, 0.8) 0%, rgba(0, 206, 201, 0.8) 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.action-icon.review {
  background: linear-gradient(135deg, rgba(253, 203, 110, 0.8) 0%, rgba(255, 165, 0, 0.8) 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.action-icon image {
  width: 48rpx;
  height: 48rpx;
}

.action-item text {
  font-size: 24rpx;
  color: #636E72;
  font-weight: 500;
}