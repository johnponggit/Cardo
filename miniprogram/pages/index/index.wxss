/* pages/index/index.wxss */

.container {
  padding: 20rpx;
  padding-bottom: 200rpx;
  background-color: #F5F5F5;
  min-height: 100vh;
}

.welcome-section {
  padding: 20rpx 10rpx;
  margin-bottom: 20rpx;
}

.greeting {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.date {
  font-size: 28rpx;
  color: #999999;
}

.stats-section {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.stat-card {
  flex: 1;
  border-radius: 16rpx;
  padding: 24rpx;
  color: #FFFFFF;
}

.todo-stat {
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
}

.card-stat {
  background: linear-gradient(135deg, #52C41A 0%, #3DA31A 100%);
}

.stat-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.stat-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 8rpx;
}

.stat-title {
  font-size: 28rpx;
  font-weight: 500;
}

.stat-body {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 600;
}

.stat-value.doing {
  color: #FFD591;
}

.stat-value.done {
  color: #B7EB8F;
}

.stat-value.due {
  color: #FFA39E;
}

.stat-value.new {
  color: #95DE64;
}

.stat-label {
  font-size: 22rpx;
  opacity: 0.9;
  margin-top: 4rpx;
}

.review-section {
  margin-bottom: 20rpx;
}

.review-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #722ED1 0%, #531DAB 100%);
  padding: 24rpx;
  border-radius: 16rpx;
}

.review-content {
  display: flex;
  align-items: center;
}

.review-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 16rpx;
}

.review-text {
  display: flex;
  flex-direction: column;
}

.review-title {
  font-size: 30rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.review-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4rpx;
}

.arrow-icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.8;
}

.recent-section {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.section-more {
  font-size: 26rpx;
  color: #4A90D9;
}

.recent-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.recent-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background-color: #F5F5F5;
  border-radius: 8rpx;
}

.item-status {
  width: 8rpx;
  height: 40rpx;
  border-radius: 4rpx;
  margin-right: 12rpx;
}

.item-status.pending {
  background-color: #999999;
}

.item-status.doing {
  background-color: #4A90D9;
}

.item-status.done {
  background-color: #52C41A;
}

.item-content {
  flex: 1;
  min-width: 0;
}

.item-title {
  font-size: 28rpx;
  color: #333333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}

.item-category {
  font-size: 22rpx;
  color: #999999;
  margin-top: 4rpx;
  display: block;
}

.item-priority {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.priority-1 {
  background-color: #FF4D4F;
}

.priority-2 {
  background-color: #FAAD14;
}

.priority-3 {
  background-color: #52C41A;
}

.empty-recent {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.empty-recent text {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 16rpx;
}

.btn-add {
  background-color: #4A90D9;
  color: #FFFFFF;
  font-size: 26rpx;
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
}

.quick-actions {
  display: flex;
  justify-content: space-around;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.action-icon.todo {
  background-color: #E8F2FC;
}

.action-icon.card {
  background-color: #F6FFED;
}

.action-icon.review {
  background-color: #F9F0FF;
}

.action-icon image {
  width: 40rpx;
  height: 40rpx;
}

.action-item text {
  font-size: 24rpx;
  color: #666666;
}