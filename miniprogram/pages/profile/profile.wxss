/* pages/profile/profile.wxss 玻璃拟态风格 */

.container {
  padding: 24rpx;
  padding-bottom: 120rpx;
  background: linear-gradient(135deg, #E0C3FC 0%, #8EC5FC 100%);
  background-attachment: fixed;
  min-height: 100vh;
}

/* 用户区域 */
.user-section {
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(31, 38, 135, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border: 4rpx solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.25);
}

.user-text {
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 40rpx;
  font-weight: 700;
  color: #2D3436;
  margin-bottom: 8rpx;
}

.user-id {
  font-size: 24rpx;
  color: #636E72;
  font-weight: 500;
}

.logout-btn {
  margin-left: auto;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(10rpx);
  color: #636E72;
  font-size: 24rpx;
  border-radius: 30rpx;
  padding: 12rpx 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  font-weight: 500;
}

/* 统计区域 */
.stats-section {
  margin-bottom: 24rpx;
}

.stats-card {
  display: flex;
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(31, 38, 135, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.stats-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-value {
  font-size: 48rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.stats-label {
  font-size: 24rpx;
  color: #636E72;
  margin-top: 8rpx;
  font-weight: 500;
}

.stats-divider {
  width: 1rpx;
  background: linear-gradient(180deg, transparent, rgba(108, 92, 231, 0.3), transparent);
  margin: 0 20rpx;
}

/* 菜单区域 */
.menu-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.menu-group {
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(31, 38, 135, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.5);
  transition: background 0.2s ease;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: rgba(255, 255, 255, 0.3);
}

.menu-icon {
  width: 44rpx;
  height: 44rpx;
  margin-right: 16rpx;
  opacity: 0.9;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #2D3436;
  font-weight: 500;
}

.menu-text.danger {
  color: #E17055;
}

.menu-arrow {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.5;
}

/* 版本信息 */
.version {
  text-align: center;
  margin-top: 48rpx;
}

.version text {
  font-size: 24rpx;
  color: #636E72;
  font-weight: 500;
}