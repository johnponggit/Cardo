<!-- pages/profile/profile.wxml -->
<view class="container">
  <!-- 用户信息 -->
  <view class="user-section">
    <view class="user-info" wx:if="{{userInfo}}">
      <image class="avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" />
      <view class="user-text">
        <text class="nickname">{{userInfo.nickName || '未设置昵称'}}</text>
        <text class="user-id">ID: {{openid || '未登录'}}</text>
      </view>
    </view>
    <view class="user-info" wx:else bindtap="onLogin">
      <image class="avatar" src="/images/default-avatar.png" mode="aspectFill" />
      <view class="user-text">
        <text class="nickname">点击登录</text>
        <text class="user-id">登录后同步数据</text>
      </view>
    </view>
  </view>

  <!-- 数据统计 -->
  <view class="stats-section">
    <view class="stats-card">
      <view class="stats-item">
        <text class="stats-value">{{stats.totalTodos}}</text>
        <text class="stats-label">待办总数</text>
      </view>
      <view class="stats-divider"></view>
      <view class="stats-item">
        <text class="stats-value">{{stats.totalCards}}</text>
        <text class="stats-label">卡片总数</text>
      </view>
      <view class="stats-divider"></view>
      <view class="stats-item">
        <text class="stats-value">{{stats.reviewDays}}</text>
        <text class="stats-label">复习天数</text>
      </view>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="menu-section">
    <view class="menu-group">
      <view class="menu-item" bindtap="onExport">
        <image src="/images/export.png" class="menu-icon" mode="aspectFit" />
        <text class="menu-text">导出数据</text>
        <image src="/images/arrow-right.png" class="menu-arrow" mode="aspectFit" />
      </view>
      <view class="menu-item" bindtap="onImport">
        <image src="/images/import.png" class="menu-icon" mode="aspectFit" />
        <text class="menu-text">导入数据</text>
        <image src="/images/arrow-right.png" class="menu-arrow" mode="aspectFit" />
      </view>
    </view>

    <view class="menu-group">
      <view class="menu-item" bindtap="onReminder">
        <image src="/images/reminder.png" class="menu-icon" mode="aspectFit" />
        <text class="menu-text">复习提醒</text>
        <switch checked="{{reminderEnabled}}" bindchange="onReminderChange" />
      </view>
      <view class="menu-item" bindtap="onTheme">
        <image src="/images/theme.png" class="menu-icon" mode="aspectFit" />
        <text class="menu-text">深色模式</text>
        <switch checked="{{darkMode}}" bindchange="onThemeChange" />
      </view>
    </view>

    <view class="menu-group">
      <view class="menu-item" bindtap="onFeedback">
        <image src="/images/feedback.png" class="menu-icon" mode="aspectFit" />
        <text class="menu-text">意见反馈</text>
        <image src="/images/arrow-right.png" class="menu-arrow" mode="aspectFit" />
      </view>
      <view class="menu-item" bindtap="onAbout">
        <image src="/images/about.png" class="menu-icon" mode="aspectFit" />
        <text class="menu-text">关于我们</text>
        <image src="/images/arrow-right.png" class="menu-arrow" mode="aspectFit" />
      </view>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version">
    <text>版本 1.0.0</text>
  </view>
</view>