/* pages/card/card.wxss */

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #F5F5F5;
}

.tag-scroll {
  background-color: #FFFFFF;
  white-space: nowrap;
  padding: 16rpx 20rpx;
  border-bottom: 1rpx solid #E8E8E8;
}

.tag-list {
  display: inline-flex;
}

.tag-item {
  display: inline-block;
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  color: #666666;
  background-color: #F5F5F5;
  border-radius: 20rpx;
  margin-right: 16rpx;
  transition: all 0.3s ease;
}

.tag-item.active {
  background-color: #E8F2FC;
  color: #4A90D9;
}

.stats-bar {
  display: flex;
  background-color: #FFFFFF;
  padding: 24rpx;
  border-bottom: 1rpx solid #E8E8E8;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 600;
  color: #333333;
}

.stat-value.due {
  color: #FF4D4F;
}

.stat-value.new {
  color: #52C41A;
}

.stat-label {
  font-size: 24rpx;
  color: #999999;
  margin-top: 4rpx;
}

.review-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  margin: 20rpx;
  padding: 24rpx;
  border-radius: 16rpx;
}

.review-info {
  display: flex;
  align-items: center;
}

.review-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 16rpx;
}

.review-text {
  display: flex;
  flex-direction: column;
}

.review-title {
  font-size: 30rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.review-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4rpx;
}

.arrow-icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.8;
}

.card-list {
  flex: 1;
  padding: 0 20rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-state image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 20rpx;
}

.empty-state text {
  color: #999999;
  font-size: 28rpx;
}

.empty-hint {
  font-size: 24rpx !important;
  margin-top: 12rpx;
}

.load-more {
  text-align: center;
  padding: 30rpx;
  color: #999999;
  font-size: 24rpx;
}

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 180rpx;
  width: 100rpx;
  height: 100rpx;
  background-color: #4A90D9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 217, 0.4);
  z-index: 100;
}

.fab image {
  width: 48rpx;
  height: 48rpx;
}