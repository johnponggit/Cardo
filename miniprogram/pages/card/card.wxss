/* pages/card/card.wxss 玻璃拟态风格 */

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(135deg, #E0C3FC 0%, #8EC5FC 100%);
  background-attachment: fixed;
}

/* 标签筛选 */
.tag-scroll {
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  white-space: nowrap;
  padding: 16rpx 20rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.3);
}

.tag-list {
  display: inline-flex;
}

.tag-item {
  display: inline-block;
  padding: 14rpx 28rpx;
  font-size: 26rpx;
  color: #636E72;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(10rpx);
  border-radius: 30rpx;
  margin-right: 16rpx;
  transition: all 0.3s ease;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  font-weight: 500;
}

.tag-item.active {
  background: linear-gradient(135deg, rgba(0, 184, 148, 0.8) 0%, rgba(0, 206, 201, 0.8) 100%);
  color: #FFFFFF;
  border-color: transparent;
  box-shadow: 0 4rpx 16rpx rgba(0, 184, 148, 0.25);
}

/* 统计信息 */
.stats-bar {
  display: flex;
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  padding: 28rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.3);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #2D3436;
}

.stat-value.due {
  color: #E17055;
}

.stat-value.new {
  color: #00B894;
}

.stat-label {
  font-size: 24rpx;
  color: #636E72;
  margin-top: 6rpx;
  font-weight: 500;
}

/* 复习入口 */
.review-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, rgba(253, 203, 110, 0.9) 0%, rgba(255, 165, 0, 0.9) 100%);
  margin: 20rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(253, 203, 110, 0.3);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.review-info {
  display: flex;
  align-items: center;
}

.review-icon {
  width: 56rpx;
  height: 56rpx;
  margin-right: 20rpx;
}

.review-text {
  display: flex;
  flex-direction: column;
}

.review-title {
  font-size: 32rpx;
  color: #FFFFFF;
  font-weight: 600;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.review-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 6rpx;
}

.arrow-icon {
  width: 36rpx;
  height: 36rpx;
  opacity: 0.9;
}

/* 卡片列表 */
.card-list {
  flex: 1;
  padding: 0 20rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-state image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 24rpx;
  opacity: 0.8;
}

.empty-state text {
  color: #636E72;
  font-size: 28rpx;
}

.empty-hint {
  font-size: 24rpx !important;
  margin-top: 12rpx;
  color: #B2BEC3;
}

.load-more {
  text-align: center;
  padding: 32rpx;
  color: #636E72;
  font-size: 26rpx;
}

/* 浮动按钮 */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 180rpx;
  width: 112rpx;
  height: 112rpx;
  background: linear-gradient(135deg, #00B894 0%, #00CEC9 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 40rpx rgba(0, 184, 148, 0.5);
  z-index: 100;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.fab image {
  width: 52rpx;
  height: 52rpx;
}