/* pages/review/review.wxss */

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #F5F5F5;
  padding: 20rpx;
}

.progress-header {
  background-color: #FFFFFF;
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.progress-text {
  font-size: 28rpx;
  color: #333333;
}

.progress-bar {
  height: 12rpx;
  background-color: #E8E8E8;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4A90D9 0%, #52C41A 100%);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.card-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 0 10rpx;
}

.finished-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.finish-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
}

.finish-title {
  font-size: 40rpx;
  color: #333333;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.finish-desc {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 40rpx;
}

.result-stats {
  display: flex;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.result-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: #FFFFFF;
  padding: 20rpx 32rpx;
  border-radius: 12rpx;
  min-width: 100rpx;
}

.result-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #4A90D9;
}

.result-label {
  font-size: 24rpx;
  color: #999999;
  margin-top: 4rpx;
}

.btn-finish {
  width: 300rpx;
  background-color: #4A90D9;
  color: #FFFFFF;
  font-size: 32rpx;
  border-radius: 40rpx;
}

.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.empty-state image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 20rpx;
}

.empty-state text {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 32rpx;
}

.btn-back {
  background-color: #4A90D9;
  color: #FFFFFF;
  font-size: 28rpx;
  padding: 20rpx 60rpx;
  border-radius: 40rpx;
}

.loading-state {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-state text {
  font-size: 28rpx;
  color: #999999;
}