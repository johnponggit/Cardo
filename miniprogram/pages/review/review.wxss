/* pages/review/review.wxss 玻璃拟态风格 */

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: linear-gradient(135deg, #E0C3FC 0%, #8EC5FC 100%);
  background-attachment: fixed;
  padding: 24rpx;
}

/* 进度头部 */
.progress-header {
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  padding: 28rpx;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(31, 38, 135, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.progress-text {
  font-size: 28rpx;
  color: #2D3436;
  font-weight: 600;
}

.progress-bar {
  height: 14rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 7rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #667eea 0%, #00B894 100%);
  border-radius: 7rpx;
  transition: width 0.3s ease;
}

/* 卡片区域 */
.card-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 0 10rpx;
}

/* 完成状态 */
.finished-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.finish-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
}

.finish-title {
  font-size: 44rpx;
  color: #2D3436;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.finish-desc {
  font-size: 28rpx;
  color: #636E72;
  margin-bottom: 40rpx;
}

/* 结果统计 */
.result-stats {
  display: flex;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.result-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20rpx);
  padding: 24rpx 36rpx;
  border-radius: 20rpx;
  min-width: 100rpx;
  box-shadow: 0 4rpx 16rpx rgba(31, 38, 135, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.result-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #6C5CE7;
}

.result-label {
  font-size: 24rpx;
  color: #636E72;
  margin-top: 6rpx;
  font-weight: 500;
}

.btn-finish {
  width: 320rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  border-radius: 50rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

/* 空状态 */
.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.empty-state image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 24rpx;
  opacity: 0.8;
}

.empty-state text {
  font-size: 28rpx;
  color: #636E72;
  margin-bottom: 32rpx;
}

.btn-back {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #FFFFFF;
  font-size: 28rpx;
  padding: 22rpx 64rpx;
  border-radius: 50rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.loading-state {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-state text {
  font-size: 28rpx;
  color: #636E72;
}