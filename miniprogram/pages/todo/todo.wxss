/* pages/todo/todo.wxss 玻璃拟态风格 */

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(135deg, #E0C3FC 0%, #8EC5FC 100%);
  background-attachment: fixed;
}

/* 筛选栏 */
.filter-bar {
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  padding: 20rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.3);
}

.filter-tabs {
  display: flex;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 50rpx;
  padding: 6rpx;
  box-shadow: inset 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.filter-tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 26rpx;
  color: #636E72;
  border-radius: 44rpx;
  transition: all 0.3s ease;
  font-weight: 500;
}

.filter-tab.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
}

/* 分类筛选 */
.category-scroll {
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  white-space: nowrap;
  padding: 16rpx 20rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.3);
}

.category-list {
  display: inline-flex;
}

.category-item {
  display: inline-block;
  padding: 14rpx 28rpx;
  font-size: 26rpx;
  color: #636E72;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(10rpx);
  border-radius: 30rpx;
  margin-right: 16rpx;
  transition: all 0.3s ease;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  font-weight: 500;
}

.category-item.active {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.8) 0%, rgba(118, 75, 162, 0.8) 100%);
  color: #FFFFFF;
  border-color: transparent;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.25);
}

/* 列表 */
.todo-list {
  flex: 1;
  padding: 20rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-state image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 24rpx;
  opacity: 0.8;
}

.empty-state text {
  color: #636E72;
  font-size: 28rpx;
}

.empty-hint {
  font-size: 24rpx !important;
  margin-top: 12rpx;
  color: #B2BEC3;
}

.load-more {
  text-align: center;
  padding: 32rpx;
  color: #636E72;
  font-size: 26rpx;
}

/* 浮动按钮 */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 180rpx;
  width: 112rpx;
  height: 112rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 40rpx rgba(102, 126, 234, 0.5);
  z-index: 100;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.fab image {
  width: 52rpx;
  height: 52rpx;
}