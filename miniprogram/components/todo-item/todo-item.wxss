/* components/todo-item/todo-item.wxss 玻璃拟态风格 */

.todo-item {
  display: flex;
  align-items: flex-start;
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  padding: 28rpx;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(31, 38, 135, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  transition: all 0.3s ease;
}

.todo-item:active {
  background: rgba(255, 255, 255, 0.5);
  transform: scale(0.98);
}

.todo-checkbox {
  flex-shrink: 0;
  padding-right: 20rpx;
  padding-top: 4rpx;
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid rgba(102, 126, 234, 0.4);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  background: rgba(255, 255, 255, 0.6);
}

.checkbox.checked {
  background: linear-gradient(135deg, #00B894 0%, #00CEC9 100%);
  border-color: transparent;
  box-shadow: 0 4rpx 12rpx rgba(0, 184, 148, 0.3);
}

.checkbox image {
  width: 26rpx;
  height: 26rpx;
}

.todo-content {
  flex: 1;
  min-width: 0;
}

.todo-header {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.todo-title {
  flex: 1;
  font-size: 30rpx;
  color: #2D3436;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  font-weight: 500;
}

.todo-title.done {
  color: #B2BEC3;
  text-decoration: line-through;
}

.todo-priority {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.priority-1 {
  background: linear-gradient(135deg, #E17055 0%, #D63031 100%);
  box-shadow: 0 2rpx 8rpx rgba(225, 112, 85, 0.4);
}

.priority-2 {
  background: linear-gradient(135deg, #FDCB6E 0%, #F39C12 100%);
  box-shadow: 0 2rpx 8rpx rgba(253, 203, 110, 0.4);
}

.priority-3 {
  background: linear-gradient(135deg, #00B894 0%, #00CEC9 100%);
  box-shadow: 0 2rpx 8rpx rgba(0, 184, 148, 0.4);
}

.todo-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: 8rpx;
}

.todo-category {
  font-size: 24rpx;
  color: #FFFFFF;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  margin-right: 12rpx;
  font-weight: 500;
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.25);
}

.todo-time {
  font-size: 24rpx;
  color: #636E72;
  font-weight: 500;
}

.todo-link {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.5);
  backdrop-filter: blur(10rpx);
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  margin-top: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.link-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 12rpx;
}

.link-text {
  font-size: 24rpx;
  color: #6C5CE7;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  font-weight: 500;
}

.todo-card-link {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.15) 0%, rgba(118, 75, 162, 0.15) 100%);
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  margin-top: 12rpx;
  border: 1rpx solid rgba(102, 126, 234, 0.2);
}

.card-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 12rpx;
}

.todo-card-link text {
  font-size: 24rpx;
  color: #6C5CE7;
  font-weight: 500;
}

.todo-actions {
  flex-shrink: 0;
  padding-left: 16rpx;
}

.action-btn {
  width: 44rpx;
  height: 44rpx;
  opacity: 0.5;
  transition: opacity 0.2s ease;
}

.action-btn:active {
  opacity: 0.8;
}