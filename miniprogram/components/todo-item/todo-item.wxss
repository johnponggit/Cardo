/* components/todo-item/todo-item.wxss */

.todo-item {
  display: flex;
  align-items: flex-start;
  background-color: #FFFFFF;
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.todo-checkbox {
  flex-shrink: 0;
  padding-right: 20rpx;
  padding-top: 4rpx;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #DCDCDC;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.checkbox.checked {
  background-color: #52C41A;
  border-color: #52C41A;
}

.checkbox image {
  width: 24rpx;
  height: 24rpx;
}

.todo-content {
  flex: 1;
  min-width: 0;
}

.todo-header {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.todo-title {
  flex: 1;
  font-size: 30rpx;
  color: #333333;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.todo-title.done {
  color: #999999;
  text-decoration: line-through;
}

.todo-priority {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.priority-1 {
  background-color: #FF4D4F;
}

.priority-2 {
  background-color: #FAAD14;
}

.priority-3 {
  background-color: #52C41A;
}

.todo-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: 8rpx;
}

.todo-category {
  font-size: 24rpx;
  color: #FFFFFF;
  background-color: #4A90D9;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  margin-right: 12rpx;
}

.todo-time {
  font-size: 24rpx;
  color: #999999;
}

.todo-link {
  display: flex;
  align-items: center;
  background-color: #F5F5F5;
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
  margin-top: 12rpx;
}

.link-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 8rpx;
}

.link-text {
  font-size: 24rpx;
  color: #4A90D9;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

.todo-card-link {
  display: flex;
  align-items: center;
  background-color: #E8F2FC;
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
  margin-top: 12rpx;
}

.card-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 8rpx;
}

.todo-card-link text {
  font-size: 24rpx;
  color: #4A90D9;
}

.todo-actions {
  flex-shrink: 0;
  padding-left: 16rpx;
}

.action-btn {
  width: 40rpx;
  height: 40rpx;
  opacity: 0.6;
}