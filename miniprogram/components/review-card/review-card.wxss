/* components/review-card/review-card.wxss */

.review-card {
  position: relative;
  width: 100%;
  perspective: 1000px;
}

.card-face {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 40rpx;
  min-height: 400rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  display: flex;
  flex-direction: column;
  transition: all 0.6s ease;
  transform-style: preserve-3d;
  position: relative;
}

.card-face.front {
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
}

.card-face.back {
  background: linear-gradient(135deg, #52C41A 0%, #3DA31A 100%);
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  opacity: 0;
  transform: rotateY(180deg);
}

.card-face.active {
  opacity: 1;
  transform: rotateY(0deg);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  background-color: rgba(255, 255, 255, 0.2);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.card-count {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.card-body {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
}

.card-text {
  font-size: 36rpx;
  color: #FFFFFF;
  line-height: 1.6;
  text-align: center;
  word-break: break-all;
}

.card-footer {
  text-align: center;
}

.hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.rating-buttons {
  display: flex;
  gap: 16rpx;
  margin-top: 32rpx;
  padding: 0 20rpx;
  opacity: 0;
  transform: translateY(20rpx);
  transition: all 0.3s ease;
  pointer-events: none;
}

.rating-buttons.visible {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}

.rating-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 12rpx;
  border-radius: 16rpx;
  transition: all 0.2s ease;
}

.rating-btn:active {
  transform: scale(0.95);
}

.rating-btn.fail {
  background-color: #FFF1F0;
  border: 2rpx solid #FFA39E;
}

.rating-btn.fail .rating-label {
  color: #FF4D4F;
}

.rating-btn.hard {
  background-color: #FFF7E6;
  border: 2rpx solid #FFD591;
}

.rating-btn.hard .rating-label {
  color: #FA8C16;
}

.rating-btn.good {
  background-color: #E6F7FF;
  border: 2rpx solid #91D5FF;
}

.rating-btn.good .rating-label {
  color: #1890FF;
}

.rating-btn.easy {
  background-color: #F6FFED;
  border: 2rpx solid #B7EB8F;
}

.rating-btn.easy .rating-label {
  color: #52C41A;
}

.rating-label {
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.rating-desc {
  font-size: 20rpx;
  color: #999999;
}