/* components/review-card/review-card.wxss 玻璃拟态风格 */

.review-card {
  position: relative;
  width: 100%;
  perspective: 1000px;
}

.card-face {
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 32rpx;
  padding: 48rpx;
  min-height: 400rpx;
  box-shadow: 0 12rpx 40rpx rgba(31, 38, 135, 0.15);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  display: flex;
  flex-direction: column;
  transition: all 0.6s ease;
  transform-style: preserve-3d;
  position: relative;
}

.card-face.front {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.9) 0%, rgba(118, 75, 162, 0.9) 100%);
}

.card-face.back {
  background: linear-gradient(135deg, rgba(0, 184, 148, 0.9) 0%, rgba(0, 206, 201, 0.9) 100%);
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  opacity: 0;
  transform: rotateY(180deg);
}

.card-face.active {
  opacity: 1;
  transform: rotateY(0deg);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10rpx);
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
  font-weight: 500;
}

.card-count {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
}

.card-body {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
}

.card-text {
  font-size: 36rpx;
  color: #FFFFFF;
  line-height: 1.6;
  text-align: center;
  word-break: break-all;
  font-weight: 500;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.card-footer {
  text-align: center;
}

.hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 500;
}

.rating-buttons {
  display: flex;
  gap: 16rpx;
  margin-top: 32rpx;
  padding: 0 20rpx;
  opacity: 0;
  transform: translateY(20rpx);
  transition: all 0.3s ease;
  pointer-events: none;
}

.rating-buttons.visible {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}

.rating-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 12rpx;
  border-radius: 20rpx;
  transition: all 0.2s ease;
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
}

.rating-btn:active {
  transform: scale(0.95);
}

.rating-btn.fail {
  background: rgba(225, 112, 85, 0.2);
  border: 2rpx solid rgba(225, 112, 85, 0.4);
}

.rating-btn.fail .rating-label {
  color: #E17055;
}

.rating-btn.hard {
  background: rgba(253, 203, 110, 0.2);
  border: 2rpx solid rgba(253, 203, 110, 0.4);
}

.rating-btn.hard .rating-label {
  color: #F39C12;
}

.rating-btn.good {
  background: rgba(102, 126, 234, 0.2);
  border: 2rpx solid rgba(102, 126, 234, 0.4);
}

.rating-btn.good .rating-label {
  color: #6C5CE7;
}

.rating-btn.easy {
  background: rgba(0, 184, 148, 0.2);
  border: 2rpx solid rgba(0, 184, 148, 0.4);
}

.rating-btn.easy .rating-label {
  color: #00B894;
}

.rating-label {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 6rpx;
}

.rating-desc {
  font-size: 20rpx;
  color: #636E72;
  font-weight: 500;
}