/* components/card-item/card-item.wxss 玻璃拟态风格 */

.card-item {
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  padding: 28rpx;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(31, 38, 135, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  transition: all 0.3s ease;
}

.card-item:active {
  background: rgba(255, 255, 255, 0.5);
  transform: scale(0.98);
}

.card-front {
  margin-bottom: 16rpx;
}

.front-text {
  font-size: 30rpx;
  color: #2D3436;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  font-weight: 500;
}

.card-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag {
  font-size: 22rpx;
  color: #00B894;
  background: rgba(0, 184, 148, 0.15);
  backdrop-filter: blur(10rpx);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 500;
  border: 1rpx solid rgba(0, 184, 148, 0.2);
}

.card-status {
  font-size: 24rpx;
  color: #636E72;
  font-weight: 500;
}

.card-progress {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.progress-bar {
  flex: 1;
  height: 10rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 5rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #00B894 0%, #00CEC9 100%);
  border-radius: 5rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 24rpx;
  color: #00B894;
  min-width: 60rpx;
  font-weight: 600;
}

.card-actions {
  position: absolute;
  right: 24rpx;
  top: 24rpx;
}

.action-btn {
  width: 44rpx;
  height: 44rpx;
  opacity: 0.5;
  transition: opacity 0.2s ease;
}

.action-btn:active {
  opacity: 0.8;
}